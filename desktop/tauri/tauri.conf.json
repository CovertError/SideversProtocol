{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sidevers",
  "version": "0.1.0",
  "identifier": "com.sidevers.desktop",
  "build": {
    "frontendDist": "../tauri/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sidevers",
        "width": 980,
        "height": 760,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "SocialNetworking",
    "shortDescription": "Sidevers reference desktop client",
    "longDescription": "Sidevers reference client — keygen, addresses, direct messages.",
    "icon": []
  }
}
